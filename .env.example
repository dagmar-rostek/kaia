# KAIA – Kinetic AI Agent
# API Keys — Vorlage. Kopiere diese Datei zu .env und trage deine Keys ein.
# .env wird NICHT versioniert (siehe .gitignore).

# ── LLM Provider ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
MISTRAL_API_KEY=...

# ── Voice / TTS ───────────────────────────────────────────────────────────────
# ELEVENLABS_API_KEY=...       # optional — nur wenn ElevenLabs TTS genutzt wird

# ── Deployment ────────────────────────────────────────────────────────────────
# DATA_DIR=/app/data           # Railway: Pfad zum gemounteten Volume
#                              # Lokal: weglassen (default: "data/")
