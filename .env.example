# KAIA – Kinetic AI Agent
# API Keys — Vorlage. Kopiere diese Datei zu .env und trage deine Keys ein.
# .env wird NICHT versioniert (siehe .gitignore).

# ── LLM Provider ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
MISTRAL_API_KEY=...

# ── Voice / TTS ───────────────────────────────────────────────────────────────
# ELEVENLABS_API_KEY=...       # optional — nur wenn ElevenLabs TTS genutzt wird

# ── Datenbank ─────────────────────────────────────────────────────────────────
# Lokal:       weglassen — SQLite wird automatisch genutzt (data/kaia.db)
# Hetzner:     wird in docker-compose.yml automatisch gesetzt
# DATABASE_URL=postgresql://kaia:deinPasswort@localhost:5432/kaia

# ── Deployment ────────────────────────────────────────────────────────────────
# DATA_DIR=/app/data           # Hetzner: Pfad zum gemounteten Volume
#                              # Lokal: weglassen (default: "data/")

# ── Admin-Dashboard ───────────────────────────────────────────────────────────
# ADMIN_PASSWORD=sicheresAdminPasswort

# ── PostgreSQL (nur für docker-compose.yml) ───────────────────────────────────
# POSTGRES_PASSWORD=sicheresPasswortHierEintragen
